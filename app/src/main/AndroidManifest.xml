<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Glyph Matrix にアクセスするために必須 -->
    <uses-permission android:name="com.nothing.ketchum.permission.ENABLE" />

    <!-- ショー中 (最大約70秒) の CPU スリープ抑止。Doze で delay() が遅れて
         花火がかくかくする問題への対策 (2026-07-03 実機で確認) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GlyphHanabi">

        <!-- Nothing API キー（"test" はデバッグモード用、48時間で失効する） -->
        <meta-data
            android:name="NothingKey"
            android:value="test" />

        <!-- 使い方表示の最小 Activity。インストール直後の stopped 状態を
             ユーザー自身が解除できるようにするために必須 (Activity なしだと
             Toy に選んでも bind されない: 2026-07-03 実機確認) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Glyph Hanabi Toy Service -->

        <service
            android:name=".GlyphHanabiService"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="com.nothing.glyph.TOY" />
            </intent-filter>

            <!-- Toy の表示名 -->
            <meta-data
                android:name="com.nothing.glyph.toy.name"
                android:resource="@string/toy_name" />

            <!-- Toy のプレビュー画像 -->
            <meta-data
                android:name="com.nothing.glyph.toy.image"
                android:resource="@drawable/toy_preview" />

            <!-- Toy の説明文 -->
            <meta-data
                android:name="com.nothing.glyph.toy.summary"
                android:resource="@string/toy_summary" />

            <!-- ⚠️ Phone (4a) Pro で AOD Toy として認識されるために必須 -->
            <meta-data
                android:name="com.nothing.glyph.toy.aod_support"
                android:value="1" />
        </service>

    </application>

</manifest>
